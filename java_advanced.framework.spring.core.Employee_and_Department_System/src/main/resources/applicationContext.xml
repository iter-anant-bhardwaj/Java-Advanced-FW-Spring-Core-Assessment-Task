<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
       http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Department Bean -->
    <bean id="department"
          class="com.capgemini.java_development.java_advanced.framework.spring.core.Employee_and_Department_System.entity.Department">

        <property name="id" value="101"/>
        <property name="name" value="HR"/>
        <property name="location" value="Delhi"/>

    </bean>

    <!-- Employee Bean -->
    <bean id="employee"
          class="com.capgemini.java_development.java_advanced.framework.spring.core.Employee_and_Department_System.entity.Employee">

        <property name="id" value="501"/>
        <property name="name" value="Kavita"/>
        <property name="salary" value="70000"/>

        <!-- Many-to-One Mapping -->
        <property name="department" ref="department"/>

    </bean>

</beans>